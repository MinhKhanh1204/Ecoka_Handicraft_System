@FeedbackAPI_HostAddress = http://localhost:5271

# ==================== FEEDBACKS ====================

GET {{FeedbackAPI_HostAddress}}/api/feedbacks
Accept: application/json

###

GET {{FeedbackAPI_HostAddress}}/api/feedbacks/1
Accept: application/json

###

GET {{FeedbackAPI_HostAddress}}/api/feedbacks/filter?productId=P001&minRating=4
Accept: application/json

###

POST {{FeedbackAPI_HostAddress}}/api/feedbacks
Content-Type: application/json

{
  "customerID": "CUS001",
  "productID": "P001",
  "orderID": "ORD001",
  "rating": 5,
  "comment": "Great product!"
}

###

PUT {{FeedbackAPI_HostAddress}}/api/feedbacks/1
Content-Type: application/json

{
  "rating": 4,
  "comment": "Updated comment"
}

###

DELETE {{FeedbackAPI_HostAddress}}/api/feedbacks/1
Accept: application/json

###

# ==================== FEEDBACK REPLIES ====================

GET {{FeedbackAPI_HostAddress}}/api/feedbacks/1/replies
Accept: application/json

###

GET {{FeedbackAPI_HostAddress}}/api/feedbacks/1/replies/1
Accept: application/json

###

POST {{FeedbackAPI_HostAddress}}/api/feedbacks/1/replies
Content-Type: application/json

{
  "staffID": "STAFF001",
  "replyContent": "Thank you for your feedback!"
}

###

PUT {{FeedbackAPI_HostAddress}}/api/feedbacks/1/replies/1
Content-Type: application/json

{
  "replyContent": "Updated reply content"
}

###

DELETE {{FeedbackAPI_HostAddress}}/api/feedbacks/1/replies/1
Accept: application/json

###
