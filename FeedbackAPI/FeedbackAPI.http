@FeedbackAPI_HostAddress = https://localhost:5271

# ==================================================
# FEEDBACKS  (REST — CRUD + Filter)
# ==================================================

GET {{FeedbackAPI_HostAddress}}/api/feedbacks
Accept: application/json

###

GET {{FeedbackAPI_HostAddress}}/api/feedbacks/1
Accept: application/json

###

# Custom filter: productId, minRating, date range, status
GET {{FeedbackAPI_HostAddress}}/api/feedbacks/filter?productId=P001&minRating=4&status=Active
Accept: application/json

###

POST {{FeedbackAPI_HostAddress}}/api/feedbacks
Content-Type: application/json

{
  "customerID": "CUS001",
  "productID": "P001",
  "orderID": "ORD001",
  "rating": 5,
  "comment": "Great product!"
}

###

PUT {{FeedbackAPI_HostAddress}}/api/feedbacks/1
Content-Type: application/json

{
  "rating": 4,
  "comment": "Updated comment"
}

###

DELETE {{FeedbackAPI_HostAddress}}/api/feedbacks/1

###

# ==================================================
# ODATA  (query with $filter / $orderby / $select / $top / $skip / $count)
# ==================================================

# All feedbacks (OData)
GET {{FeedbackAPI_HostAddress}}/odata/feedbacks
Accept: application/json

###

# Filter by ProductID
GET {{FeedbackAPI_HostAddress}}/odata/feedbacks?$filter=ProductID eq 'P001'
Accept: application/json

###

# Filter by Rating >= 4 and order by CreatedAt desc
GET {{FeedbackAPI_HostAddress}}/odata/feedbacks?$filter=Rating ge 4&$orderby=CreatedAt desc
Accept: application/json

###

# Paging + count
GET {{FeedbackAPI_HostAddress}}/odata/feedbacks?$top=10&$skip=0&$count=true
Accept: application/json

###

# Select specific fields only
GET {{FeedbackAPI_HostAddress}}/odata/feedbacks?$select=FeedbackID,CustomerID,Rating,Comment
Accept: application/json

###

