@{
    ViewData["Title"] = "Login";
}
@model LoginViewModel
<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Contact</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item active text-white">Login</li>
    </ol>
</div>
<!-- Single Page Header End -->

<!-- Start -->
<div class="container-fluid contact py-5">
    <div class="container py-5">
        <div class="p-5 bg-light rounded">
            <div class="row g-4">
                <div class="col-lg-7">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="All" style="color:red"></div>
                        <input asp-for="Username" type="text" class="w-100 form-control border-0 py-3 mb-4" placeholder="Your Name">
                        <span asp-validation-for="Username" style="color:red"></span>
                        <input asp-for="Password" type="password" class="w-100 form-control border-0 py-3 mb-4" placeholder="Enter Your Password">
                        <span asp-validation-for="Password" style="color:red"></span>
                        <button class="w-100 btn form-control border-secondary py-3 bg-white text-primary " type="submit">Login</button>
                        <a class="w-100 btn form-control border-secondary py-3 bg-white text-primary " type="button" href="/Account/Register">Register</a>
                    </form>
                </div>
                <div class="col-lg-5">
                    <div class="d-flex p-4 rounded mb-4 bg-white">
                        <i class="fas fa-map-marker-alt fa-2x text-primary me-4"></i>
                        <div>
                            <h4>Address</h4>
                            <p class="mb-2">123 Street New York.USA</p>
                        </div>
                    </div>
                    <div class="d-flex p-4 rounded mb-4 bg-white">
                        <i class="fas fa-envelope fa-2x text-primary me-4"></i>
                        <div>
                            <h4>Mail Us</h4>
                            <p class="mb-2">info@example.com</p>
                        </div>
                    </div>
                    <div class="d-flex p-4 rounded bg-white">
                        <i class="fa fa-phone-alt fa-2x text-primary me-4"></i>
                        <div>
                            <h4>Telephone</h4>
                            <p class="mb-2">(+012) 3456 7890</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}