@using MVCApplication.Models.DTOs
@model IEnumerable<Order>

@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-5">
    <h2 class="mb-4">My Orders</h2>

    <!-- SEARCH FORM -->
    <form asp-action="Search" method="get" class="mb-4">
        <div class="row g-2">

            <div class="col-md-3">
                <input type="text" name="orderId"
                       class="form-control"
                       placeholder="Order ID" />
            </div>

            <div class="col-md-2">
                <input type="date" name="from" class="form-control" />
            </div>

            <div class="col-md-2">
                <input type="date" name="to" class="form-control" />
            </div>

            <div class="col-md-2">
                <select name="paymentStatus" class="form-select">
                    <option value="">All Payment</option>
                    <option>Paid</option>
                    <option>Pending</option>
                    <option>Failed</option>
                </select>
            </div>

            <div class="col-md-2">
                <select name="tabStatus" class="form-select">
                    <option value="">All</option>
                    <option value="current">Current</option>
                    <option value="history">History</option>
                </select>
            </div>

            <div class="col-md-1">
                <button class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You have no orders yet.
        </div>
    }

    <div class="row">
        @foreach (var order in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card shadow-sm h-100 border-0">

                    <!-- HEADER -->
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <strong>#@order.OrderID</strong>
                        <span class="badge bg-primary">
                            @order.PaymentStatus
                        </span>
                    </div>

                    <!-- BODY -->
                    <div class="card-body">
                        <p>
                            <strong>Date:</strong>
                            @order.OrderDate?.ToString("dd/MM/yyyy")
                        </p>

                        <p>
                            <strong>Shipping:</strong>
                            <span class="badge bg-warning text-dark">
                                @order.ShippingStatus
                            </span>
                        </p>

                        <p>
                            <strong>Address:</strong>
                            @order.ShippingAddress
                        </p>

                        <hr />

                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="text-danger mb-0">
                                @order.TotalAmount?.ToString("N0") $
                            </h5>

                            <button class="btn btn-sm btn-primary"
                                    onclick="showOrderDetail('@order.OrderID')">
                                View Details
                            </button>
                        </div>
                    </div>

                    <!-- FOOTER -->
                    @if (order.ShippingStatus == "Pending")
                    {
                        <div class="card-footer bg-white text-end border-0">
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@order.OrderID" />

                                <button class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure you want to cancel this order?');">
                                    Cancel
                                </button>
                            </form>
                        </div>
                    }

                </div>
            </div>
        }
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="orderDetailModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">
                    🧾 Order Details
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body p-4" id="orderDetailContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-dark"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    async function showOrderDetail(orderId) {

        const modal = new bootstrap.Modal(
            document.getElementById('orderDetailModal')
        );

        modal.show();

        document.getElementById("orderDetailContent").innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-dark"></div>
            </div>`;

        const response = await fetch(`/Orders/Details/${orderId}`);

        if (!response.ok) {
            document.getElementById("orderDetailContent").innerHTML = `
                <div class="alert alert-danger">
                    Failed to load order details
                </div>`;
            return;
        }

        const html = await response.text();
        document.getElementById("orderDetailContent").innerHTML = html;
    }
</script>