@model MVCApplication.Models.DTOs.VoucherDto

@{
    ViewData["Title"] = "Voucher Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Vouchers</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Code</li>
                </ol>
            </nav>

            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h2 class="mb-0 text-center">Voucher: @Model.Code</h2>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Name</div>
                        <div class="col-sm-8">@Model.VoucherName</div>
                    </div>
                    <hr />
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Description</div>
                        <div class="col-sm-8">@Model.Description</div>
                    </div>
                    <hr />
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded text-center">
                                <span class="text-muted d-block small">Discount</span>
                                <span class="h4 text-primary">@Model.DiscountPercentage%</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded text-center">
                                <span class="text-muted d-block small">Max Reducing</span>
                                <span class="h4 text-primary">@string.Format("{0:C0}", Model.MaxReducing)</span>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Expiry Date</div>
                        <div class="col-sm-8 text-danger fw-bold">@Model.ExpiryDate?.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Remaining Quantity</div>
                        <div class="col-sm-8">@Model.Quantity</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Min Order Value</div>
                        <div class="col-sm-8">@string.Format("{0:C0}", Model.MinOrderValue)</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Status</div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.IsActive == true ? "bg-success" : "bg-secondary")">
                                @(Model.IsActive == true ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <a asp-action="Index" class="btn btn-secondary me-2">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
