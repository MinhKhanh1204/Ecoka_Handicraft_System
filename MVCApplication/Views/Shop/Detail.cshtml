@using MVCApplication.Models.DTOs
@{
    ViewData["Title"] = "Detail";
}
@model ProductDetailResponseDto

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Shop Detail</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="/Home">Home</a></li>
        <li class="breadcrumb-item"><a href="/Shop">Shop</a></li>
        <li class="breadcrumb-item active text-white">Shop Detail</li>
    </ol>
</div>
<!-- Single Page Header End -->
<!-- Single Product Start -->
<div class="container-fluid py-5 mt-5">
    <div class="container py-5">
        <div class="row g-4 mb-5">
            <div class="col-lg-12 col-xl-12">
                <div class="row g-4">

                    <!-- IMAGE -->
                    <div class="col-lg-6">
                        <div class="border rounded">
                            <img src="@Model.MainImage" class="img-fluid rounded" />
                        </div>
                    </div>

                    <!-- INFO -->
                    <div class="col-lg-6">
                        <h4 class="fw-bold mb-3">@Model.ProductName</h4>
                        <p class="mb-3">Category: @Model.Category.CategoryName</p>

                        <del>
                            @if (Model.Price != Model.FinalPrice)
                            {
                                @Model.Price.ToString("N0")
                            }
                        </del>

                        <h5 class="fw-bold mb-3">
                            @Model.FinalPrice.ToString("N0") VND
                        </h5>

                        <!-- Average Rating -->
                        <div class="d-flex mb-4" id="avg-rating">
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <span class="ms-2 text-muted" id="review-count"></span>
                        </div>

                        <p class="mb-4">@Model.Description</p>
                    </div>

                    <!-- TABS -->
                    <div class="col-lg-12">
                        <nav>
                            <div class="nav nav-tabs mb-3">
                                <button class="nav-link active"
                                        data-bs-toggle="tab"
                                        data-bs-target="#nav-about">
                                    Description
                                </button>

                                <button class="nav-link"
                                        data-bs-toggle="tab"
                                        data-bs-target="#nav-reviews">
                                    Reviews <span id="tab-review-count"></span>
                                </button>
                            </div>
                        </nav>

                        <div class="tab-content mb-5">

                            <!-- DESCRIPTION -->
                            <div class="tab-pane fade show active" id="nav-about">
                                <p>@Model.Description</p>
                            </div>

                            <!-- REVIEWS -->
                            <div class="tab-pane fade" id="nav-reviews">

                                <!-- FILTER -->
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <select id="filterRating" class="form-select">
                                            <option value="">All Ratings</option>
                                            <option value="5">5 stars</option>
                                            <option value="4">4+ stars</option>
                                            <option value="3">3+ stars</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-success"
                                                onclick="filterFeedbacks()">
                                            Filter
                                        </button>
                                    </div>
                                </div>

                                <!-- LIST -->
                                <div id="feedback-list">
                                    <div class="text-center py-3">
                                        <div class="spinner-border text-dark"></div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- FORM -->
                    <div class="col-lg-12">
                        <h4 class="mb-4 fw-bold">Leave a Reply</h4>

<textarea id="feedbackComment"
          class="form-control mb-3"
          rows="4"
          placeholder="Your review">
</textarea>

                        <div id="star-rating" style="cursor:pointer; font-size:18px;">
                            <i class="fa fa-star" data-value="1"></i>
                            <i class="fa fa-star" data-value="2"></i>
                            <i class="fa fa-star" data-value="3"></i>
                            <i class="fa fa-star" data-value="4"></i>
                            <i class="fa fa-star" data-value="5"></i>
                        </div>

                        <button id="btnSubmitFeedback"
                                class="btn btn-primary mt-3">
                            Post Comment
                        </button>

                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- Single Product End -->
@section Scripts {
    <script>

        const productId = '@Model.ProductId';
        const customerID = '@User.FindFirst("accountID")?.Value';

        let selectedRating = 0;
        let editingId = null;

        // ================= LOAD =================
        async function loadFeedbacks(minRating = null) {

            let url = `/Feedback/GetByProduct?productId=${productId}`;
            if (minRating) url += `&minRating=${minRating}`;

            try {
                const res = await fetch(url);
                const feedbacks = await res.json();
                renderFeedbacks(feedbacks);
                updateAverage(feedbacks);
            }
            catch {
                document.getElementById('feedback-list').innerHTML =
                    '<p class="text-danger">Failed to load reviews.</p>';
            }
        }

        // ================= RENDER =================
        function renderFeedbacks(feedbacks) {

            if (!feedbacks.length) {
                document.getElementById('feedback-list').innerHTML =
                    '<p class="text-muted">No reviews yet.</p>';
                return;
            }

            let html = '';

            feedbacks.forEach(fb => {

                const date = new Date(fb.createdAt)
                    .toLocaleDateString('en-US');

                let stars = '';
                for (let i = 1; i <= 5; i++) {
                    stars += `<i class="fa fa-star ${i <= fb.rating ? 'text-warning' : ''}"></i>`;
                }

                html += `
                <div class="border-bottom mb-3 pb-3">
                    <div class="d-flex justify-content-between">
                        <strong>${fb.customerID}</strong>
                        <div>${stars}</div>
                    </div>
                    <p>${fb.comment || ''}</p>

                    ${fb.customerID === customerID ? `
                        <button class="btn btn-sm btn-warning me-2"
                            onclick="editFeedback(${fb.feedbackID}, ${fb.rating}, \`${fb.comment || ''}\`)">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-danger"
                            onclick="deleteFeedback(${fb.feedbackID})">
                            Delete
                        </button>
                    ` : ''}
                </div>`;
            });

            document.getElementById('feedback-list').innerHTML = html;
        }

        // ================= AVERAGE =================
        function updateAverage(feedbacks) {

            const avg = feedbacks.length
                ? feedbacks.reduce((s,f)=>s+f.rating,0)/feedbacks.length
                : 0;

            document.querySelectorAll('#avg-rating .fa-star')
                .forEach((star,idx)=>{
                    star.classList.toggle('text-warning',
                        idx < Math.round(avg));
                });

            document.getElementById('review-count')
                .textContent = `(${feedbacks.length} reviews)`;

            document.getElementById('tab-review-count')
                .textContent = `(${feedbacks.length})`;
        }

        // ================= FILTER =================
        function filterFeedbacks() {
            const rating =
                document.getElementById('filterRating').value;
            loadFeedbacks(rating);
        }

        // ================= DELETE =================
        async function deleteFeedback(id) {

            if (!confirm("Delete this review?")) return;

            await fetch(`/Feedback/Delete/${id}`, {
                method:'DELETE'
            });

            loadFeedbacks();
        }

        // ================= EDIT =================
        function editFeedback(id, rating, comment) {

            editingId = id;
            selectedRating = rating;

            document.getElementById('feedbackComment').value = comment;

            document.querySelectorAll('#star-rating .fa-star')
                .forEach((s,idx)=>{
                    s.classList.toggle('text-warning',
                        idx < rating);
                });

            window.scrollTo({
                top: document.body.scrollHeight,
                behavior: 'smooth'
            });
        }

        // ================= STAR CLICK =================
        document.querySelectorAll('#star-rating .fa-star')
            .forEach(star=>{
                star.addEventListener('click', function(){
                    selectedRating =
                        parseInt(this.dataset.value);

                    document.querySelectorAll('#star-rating .fa-star')
                        .forEach((s,idx)=>{
                            s.classList.toggle('text-warning',
                                idx < selectedRating);
                        });
                });
            });

        // ================= CREATE / UPDATE =================
        document.getElementById('btnSubmitFeedback')
        .addEventListener('click', async function(){

            const comment =
                document.getElementById('feedbackComment')
                    .value.trim();

            if (!customerID) {
                alert('Login first');
                return;
            }

            if (!selectedRating) {
                alert('Select rating');
                return;
            }

            if (editingId) {

                await fetch(`/Feedback/Update/${editingId}`,{
                    method:'PUT',
                    headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({
                        rating:selectedRating,
                        comment:comment
                    })
                });

                editingId = null;

            } else {

                await fetch('/Feedback/Create',{
                    method:'POST',
                    headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({
                        customerID:customerID,
                        productID:productId,
                        rating:selectedRating,
                        comment:comment
                    })
                });
            }

            document.getElementById('feedbackComment').value='';
            selectedRating=0;

            document.querySelectorAll('#star-rating .fa-star')
                .forEach(s=>s.classList.remove('text-warning'));

            loadFeedbacks();
        });

        // LOAD PAGE
        loadFeedbacks();

    </script>
}