@using MVCApplication.Models.DTOs
@{
    ViewData["Title"] = "Detail";
}
@model ProductDetailResponseDto

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Shop Detail</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="/Home">Home</a></li>
        <li class="breadcrumb-item"><a href="/Shop">Shop</a></li>
        <li class="breadcrumb-item active text-white">Shop Detail</li>
    </ol>
</div>
<!-- Single Page Header End -->
<!-- Single Product Start -->
<div class="container-fluid py-5 mt-5">
    <div class="container py-5">
        <div class="row g-4 mb-5">
            <div class="col-lg-12 col-xl-12">
                <div class="row g-4">

                    <!-- IMAGE -->
                    <div class="col-lg-6">
                        <div class="border rounded">
                            <img src="@Model.MainImage" class="img-fluid rounded" />
                        </div>
                    </div>

                    <!-- INFO -->
                    <div class="col-lg-6">
                        <h4 class="fw-bold mb-3">@Model.ProductName</h4>
                        <p class="mb-3">Category: @Model.Category.CategoryName</p>
                        <del>
                            @if (Model.Price != Model.FinalPrice)
                            {
                                @Model.Price.ToString("N0")
                            }
                        </del>
                        <h5 class="fw-bold mb-3">
                            @Model.FinalPrice.ToString("N0") VND
                        </h5>

                        <!-- Nút Cart -->
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <!-- Quantity Spinner -->
                            <div class="input-group" style="width: 140px;">
                                <button class="btn btn-outline-secondary" type="button" id="btnQtyMinus">−</button>
                                <input type="text" id="inputQty"
                                       class="form-control text-center"
                                       value="1"
                                       style="width: 50px;" />
                                <button class="btn btn-outline-secondary" type="button" id="btnQtyPlus">+</button>
                            </div>

                            <button id="btnAddToCart"
                                    data-productid="@Model.ProductId"
                                    data-stock="@Model.StockQuantity"
                                    class="btn btn-primary">
                                <i class="fa fa-cart-plus me-1"></i> Add to Cart
                            </button>
                        </div>
                        <small class="text-muted">Còn <span id="stockLabel">@Model.StockQuantity</span> sản phẩm trong kho</small>

                        <!-- Average Rating -->
                        <div class="d-flex mb-4" id="avg-rating">
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <span class="ms-2 text-muted" id="review-count"></span>
                        </div>

                        <p class="mb-4">@Model.Description</p>
                    </div>

                    <!-- TABS -->
                    <div class="col-lg-12">
                        <nav>
                            <div class="nav nav-tabs mb-3">
                                <button class="nav-link active"
                                        data-bs-toggle="tab"
                                        data-bs-target="#nav-about">
                                    Description
                                </button>

                                <button class="nav-link"
                                        data-bs-toggle="tab"
                                        data-bs-target="#nav-reviews">
                                    Reviews <span id="tab-review-count"></span>
                                </button>
                            </div>
                        </nav>

                        <div class="tab-content mb-5">
                            <!-- DESCRIPTION -->
                            <div class="tab-pane fade show active" id="nav-about">
                                <p>@Model.Description</p>
                            </div>
                            <!-- REVIEWS -->
                            <div class="tab-pane fade" id="nav-reviews">
                                <!-- FILTER -->
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <select id="filterRating" class="form-select">
                                            <option value="">All Ratings</option>
                                            <option value="5">5 stars</option>
                                            <option value="4">4+ stars</option>
                                            <option value="3">3+ stars</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-success"
                                                onclick="filterFeedbacks()">
                                            Filter
                                        </button>
                                    </div>
                                </div>
                                <!-- LIST -->
                                <div id="feedback-list">
                                    <div class="text-center py-3">
                                        <div class="spinner-border text-dark"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FORM: chỉ hiện khi đã đăng nhập -->
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                    <div class="col-lg-12">
                        <h4 class="mb-4 fw-bold">Leave a Reply</h4>
<textarea id="feedbackComment"
          class="form-control mb-3"
          rows="4"
          placeholder="Your review">
</textarea>
                        <div id="star-rating" style="cursor:pointer; font-size:18px;">
                            <i class="fa fa-star" data-value="1"></i>
                            <i class="fa fa-star" data-value="2"></i>
                            <i class="fa fa-star" data-value="3"></i>
                            <i class="fa fa-star" data-value="4"></i>
                            <i class="fa fa-star" data-value="5"></i>
                        </div>
                        
                        <div class="mt-3">
                            <label for="feedbackImages" class="form-label fw-bold">Attach Photos (Optional)</label>
                            <input type="file" id="feedbackImages" class="form-control" multiple accept="image/*" onchange="previewImages()">
                            <div id="imagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                        </div>

                        <button id="btnSubmitFeedback"
                                class="btn btn-primary mt-3">
                            Post Comment
                        </button>
                    </div>
                    }
                    else
                    {
                    <div class="col-lg-12">
                        <p class="text-muted">Please <a href="/Account/Login">login</a> to leave a review.</p>
                    </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Single Product End -->
@section Scripts {
    <script>
        // ==== CART ====
        const productId = '@Model.ProductId';
        const currentUserId = '@(ViewBag.CurrentUserId ?? string.Empty)';
        const stockQty = parseInt('@Model.StockQuantity') || 0;

        // Nút − / +
        $('#btnQtyMinus').click(function () {
            const input = $('#inputQty');
            const val = parseInt(input.val()) || 1;
            if (val > 1) input.val(val - 1);
        });

        $('#btnQtyPlus').click(function () {
            const input = $('#inputQty');
            const val = parseInt(input.val()) || 1;
            if (val < stockQty) input.val(val + 1);
            else input.val(stockQty);
        });

        // Validation khi nhập tay
        $('#inputQty').on('input change', function () {
            let val = parseInt($(this).val());
            if (isNaN(val) || val < 1) val = 1;
            if (val > stockQty) val = stockQty;
            $(this).val(val);
        });

        // Add to Cart
        $('#btnAddToCart').click(function () {
            // Lấy quantity hiện tại
            let qty = parseInt($('#inputQty').val());

            // Validation
            if (isNaN(qty) || qty < 1) {
                toastr.warning('Số lượng phải ít nhất là 1.');
                $('#inputQty').val(1).focus();
                return;
            }
            if (qty > stockQty) {
                toastr.warning(`Số lượng không được vượt quá tồn kho (${stockQty}).`);
                $('#inputQty').val(stockQty).focus();
                return;
            }

            // Check Login trước khi gửi
            if (!currentUserId) {
                toastr.info('Vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng.');
                setTimeout(() => {
                    window.location.href = '/Account/Login?ReturnUrl=' + encodeURIComponent(window.location.pathname);
                }, 1500);
                return;
            }

            const btn = $(this);
            btn.prop('disabled', true).text('Đang thêm...');

            $.ajax({
                url: '/Cart/AddItem',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ ProductId: productId, Quantity: qty }),
                success: function () {
                    toastr.success(`Đã thêm ${qty} sản phẩm vào giỏ hàng!`);
                    
                    // Reset trạng thái nút thay vì chuyển trang
                    btn.prop('disabled', false).html('<i class="fa fa-cart-plus me-1"></i> Add to Cart');
                    
                    // Reset ô input về 1 (tuỳ chọn)
                    $('#inputQty').val(1);
                },
                error: function (xhr) {
                    if (xhr.status === 401) {
                        window.location.href = '/Account/Login';
                    } else {
                        toastr.error('Thêm vào giỏ hàng thất bại!\n' + (xhr.responseText || ''));
                    }
                    btn.prop('disabled', false).html('<i class="fa fa-cart-plus me-1"></i> Add to Cart');
                }
            });
        });

        // ==== FEEDBACK giữ nguyên như cũ, đồng bộ property ====
        let selectedRating = 0;
        let editingId = null;

        async function loadFeedbacks(minRating = null) {
            let url = `/Feedback/GetByProduct?productId=${productId}`;
            if (minRating) url += `&minRating=${minRating}`;
            try {
                const res = await fetch(url);
                const feedbacks = await res.json();
                renderFeedbacks(feedbacks);
                updateAverage(feedbacks);
            }
            catch {
                document.getElementById('feedback-list').innerHTML =
                    '<p class="text-danger">Failed to load reviews.</p>';
            }
        }

        function renderFeedbacks(feedbacks) {
            if (!feedbacks.length) {
                document.getElementById('feedback-list').innerHTML =
                    '<p class="text-muted">No reviews yet.</p>';
                return;
            }
            let html = '';
            feedbacks.forEach(fb => {
                const date = new Date(fb.createdAt)
                    .toLocaleDateString('en-US');
                let stars = '';
                for (let i = 1; i <= 5; i++) {
                    stars += `<i class="fa fa-star ${i <= fb.rating ? 'text-warning' : ''}"></i>`;
                }
                let imagesHtml = '';
                if (fb.imageUrls && fb.imageUrls.length > 0) {
                    imagesHtml = '<div class="d-flex flex-wrap gap-2 mt-2">';
                    fb.imageUrls.forEach(url => {
                        imagesHtml += `<img src="${url}" class="img-thumbnail" style="width: 100px; height: 100px; object-fit: cover; cursor: pointer;" onclick="window.open('${url}', '_blank')">`;
                    });
                    imagesHtml += '</div>';
                }

                html += `
                <div class="border-bottom mb-3 pb-3">
                    <div class="d-flex justify-content-between">
                        <strong>${fb.username || fb.customerID}</strong>
                        <div>${stars}</div>
                    </div>
                    <p class="mb-1">${fb.comment || ''}</p>
                    ${imagesHtml}
                    <div class="mt-2">
                        ${fb.customerID == currentUserId ? `
                            <button class="btn btn-sm btn-warning me-2"
                                onclick="editFeedback(${fb.feedbackID}, ${fb.rating}, \`${fb.comment || ''}\`)">Edit</button>
                            <button class="btn btn-sm btn-danger"
                                onclick="deleteFeedback(${fb.feedbackID})">Delete</button>
                        ` : ''}
                    </div>
                </div>`;
            });
            document.getElementById('feedback-list').innerHTML = html;
        }

        function updateAverage(feedbacks) {
            const avg = feedbacks.length
                ? feedbacks.reduce((s, f) => s + f.rating, 0) / feedbacks.length
                : 0;
            document.querySelectorAll('#avg-rating .fa-star')
                .forEach((star, idx) => {
                    star.classList.toggle('text-warning',
                        idx < Math.round(avg));
                });
            document.getElementById('review-count')
                .textContent = `(${feedbacks.length} reviews)`;
            document.getElementById('tab-review-count')
                .textContent = `(${feedbacks.length})`;
        }

        function filterFeedbacks() {
            const rating =
                document.getElementById('filterRating').value;
            loadFeedbacks(rating);
        }

        async function deleteFeedback(id) {
            if (!confirm("Delete this review?")) return;
            try {
                const res = await fetch(`/Feedback/Delete/${id}`, {
                    method: 'DELETE'
                });
                if(res.ok) {
                    toastr.success("Review deleted successfully.");
                    loadFeedbacks();
                } else {
                    toastr.error("Failed to delete review.");
                }
            } catch (e) {
                toastr.error("Err: " + e.message);
            }
        }

        function editFeedback(id, rating, comment) {
            editingId = id;
            selectedRating = rating;
            document.getElementById('feedbackComment').value = comment;
            document.querySelectorAll('#star-rating .fa-star')
                .forEach((s, idx) => {
                    s.classList.toggle('text-warning',
                        idx < rating);
                });
            window.scrollTo({
                top: document.body.scrollHeight,
                behavior: 'smooth'
            });
        }

        document.querySelectorAll('#star-rating .fa-star')
            .forEach(star => {
                star.addEventListener('click', function () {
                    selectedRating =
                        parseInt(this.dataset.value);
                    document.querySelectorAll('#star-rating .fa-star')
                        .forEach((s, idx) => {
                            s.classList.toggle('text-warning',
                                idx < selectedRating);
                        });
                });
            });

        function previewImages() {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            const files = document.getElementById('feedbackImages').files;

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'img-thumbnail';
                    img.style.width = '80px';
                    img.style.height = '80px';
                    img.style.objectFit = 'cover';
                    preview.appendChild(img);
                }
                reader.readAsDataURL(file);
            }
        }

        document.getElementById('btnSubmitFeedback')
            .addEventListener('click', async function () {
                const btn = $(this);
                const comment =
                    document.getElementById('feedbackComment')
                        .value.trim();

                // Custom Validations
                if (!selectedRating) {
                    toastr.warning('Qúy khách vui lòng chọn số sao (Rating).');
                    return;
                }
                
                if (comment.length < 10) {
                    toastr.warning('Bình luận quá ngắn. Vui lòng nhập tối thiểu 10 ký tự để tụi mình hiểu rõ hơn ý kiến của bạn.');
                    return;
                }

                // Cấm từ thô tục cơ bản (có thể mở rộng thêm)
                const badWords = ["dm", "vcl", "cc", "đm", "địt", "lồn", "cặc", "chó"];
                const lowerComment = comment.toLowerCase();
                const hasBadWord = badWords.some(word => {
                    const regex = new RegExp(`\\b${word}\\b`, 'g');
                    return regex.test(lowerComment);
                });

                if (hasBadWord) {
                    toastr.error('Bình luận của bạn chứa từ ngữ không phù hợp. Vui lòng dùng từ ngữ lịch sự nhé!');
                    return;
                }

                btn.prop('disabled', true).text('Đang gửi...');

                const formData = new FormData();
                formData.append('ProductID', productId);
                formData.append('Rating', selectedRating);
                formData.append('Comment', comment);

                const files = document.getElementById('feedbackImages').files;
                const maxSize = 10 * 1024 * 1024; // 10MB limit for Cloudinary free plan
                for (let i = 0; i < files.length; i++) {
                    if (files[i].size > maxSize) {
                        toastr.warning(`Ảnh "${files[i].name}" quá lớn (${(files[i].size / 1024 / 1024).toFixed(2)}MB). Vui lòng chọn ảnh dưới 10MB.`);
                        btn.prop('disabled', false).text('Post Comment');
                        return;
                    }
                    formData.append('Images', files[i]);
                }

                try {
                    if (editingId) {
                        const res = await fetch(`/Feedback/Update/${editingId}`, {
                            method: 'PUT',
                            body: formData
                        });
                        const data = await res.json();
                        if (!res.ok || !data.success) {
                            throw new Error(data.message || 'Lỗi khi cập nhật feedback');
                        }
                        editingId = null;
                    } else {
                        const res = await fetch('/Feedback/Create', {
                            method: 'POST',
                            body: formData
                        });
                        const data = await res.json();
                        if (!res.ok || !data.success) {
                            throw new Error(data.message || 'Lỗi khi gửi feedback');
                        }
                    }

                    document.getElementById('feedbackComment').value = '';
                    document.getElementById('feedbackImages').value = '';
                    document.getElementById('imagePreview').innerHTML = '';
                    selectedRating = 0;
                    document.querySelectorAll('#star-rating .fa-star')
                        .forEach(s => s.classList.remove('text-warning'));
                    loadFeedbacks();
                    toastr.success('Phản hồi của bạn đã được đăng thành công!');
                } catch (e) {
                    toastr.error('Lỗi: ' + e.message);
                } finally {
                    btn.prop('disabled', false).text('Post Comment');
                }
            });

        // LOAD PAGE
        loadFeedbacks();
    </script>
}