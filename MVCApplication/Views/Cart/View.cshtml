@model MVCApplication.Models.CartViewModel

@{
    ViewData["Title"] = "Your Cart";
}

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Cart</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="/Home">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Shop</a></li>
        <li class="breadcrumb-item active text-white">Cart</li>
    </ol>
</div>
<!-- Single Page Header End -->

<!-- Cart Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
        {
            <div class="text-center my-5">
                <i class="fa fa-shopping-bag fa-4x text-muted mb-3"></i>
                <h3 class="text-muted">Your cart is currently empty</h3>
                <a href="/Shop" class="btn border-secondary rounded-pill px-4 py-3 text-primary mt-4">Return to Shop</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col" style="width: 50px;">
                                <input type="checkbox" id="selectAll" class="form-check-input" style="transform: scale(1.3); cursor: pointer;">
                            </th>
                            <th scope="col">Products</th>
                            <th scope="col">Name</th>
                            <th scope="col">Price</th>
                            <th scope="col">Quantity</th>
                            <th scope="col">Total</th>
                            <th scope="col">Handle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            var itemTotal = item.Price * item.Quantity;
                            <tr>
                                <td class="align-middle">
                                    <input type="checkbox" class="form-check-input chk-item" 
                                           data-id="@item.CartItemId" 
                                           data-price="@item.Price" 
                                           data-qty="@item.Quantity" 
                                           style="transform: scale(1.3); cursor: pointer;">
                                </td>
                                <th scope="row">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default-product.png" : item.ImageUrl)" class="img-fluid me-5 rounded-circle" style="width: 80px; height: 80px;" alt="@item.ProductName" onerror="this.src='/img/single-item.jpg'">
                                    </div>
                                </th>
                                <td class="align-middle">
                                    <p class="mb-0 fs-5">@item.ProductName</p>
                                </td>
                                <td class="align-middle">
                                    <p class="mb-0 fs-5">@item.Price.ToString("N0") ₫</p>
                                </td>
                                <td class="align-middle">
                                    <div class="input-group quantity" style="width: 100px;">
                                        <div class="input-group-btn">
                                            <button class="btn btn-sm btn-minus rounded-circle bg-light border" onclick="updateQty(@item.CartItemId, -1, @item.StockQuantity)">
                                                <i class="fa fa-minus"></i>
                                            </button>
                                        </div>
                                        <input type="text" class="form-control form-control-sm text-center border-0 qty-input_@item.CartItemId" value="@item.Quantity" readonly>
                                        <div class="input-group-btn">
                                            <button class="btn btn-sm btn-plus rounded-circle bg-light border" onclick="updateQty(@item.CartItemId, 1, @item.StockQuantity)">
                                                <i class="fa fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle">
                                    <p class="mb-0 fs-5 text-primary fw-bold">@itemTotal.ToString("N0") ₫</p>
                                </td>
                                <td class="align-middle">
                                    <button class="btn btn-md rounded-circle bg-light border" onclick="deleteCartItem(@item.CartItemId)">
                                        <i class="fa fa-times text-danger"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row g-4 justify-content-end mt-5">
                <div class="col-8"></div>
                <div class="col-sm-8 col-md-7 col-lg-6 col-xl-4">
                    <div class="bg-light rounded p-4 shadow-sm">
                        <h1 class="display-6 mb-4">Cart <span class="fw-normal">Total</span></h1>
                        <div class="d-flex justify-content-between mb-4">
                            <h5 class="mb-0 me-4">Selected Items:</h5>
                            <p class="mb-0 fs-5" id="lblSelectedCount">0</p>
                        </div>
                        <div class="py-4 mb-4 border-top border-bottom d-flex justify-content-between">
                            <h5 class="mb-0 ps-4 me-4">Total Amount</h5>
                            <p class="mb-0 pe-4 fs-4 text-primary fw-bold" id="lblFinalTotal">0 ₫</p>
                        </div>
                        <button class="btn border-secondary rounded-pill w-100 py-3 text-primary text-uppercase fs-5" type="button" onclick="checkoutSelected()"><i class="fa fa-credit-card me-2"></i> Proceed Checkout</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<!-- Cart Page End -->

@section Scripts {
    <script>
        function calculateTotal() {
            let total = 0;
            let count = 0;
            $('.chk-item:checked').each(function() {
                let p = parseFloat($(this).data('price'));
                let q = parseInt($(this).data('qty'));
                total += (p * q);
                count++;
            });
            $('#lblSelectedCount').text(count);
            
            let formatter = new Intl.NumberFormat('vi-VN');
            $('#lblFinalTotal').text(formatter.format(total) + " ₫");
        }

        $('#selectAll').change(function() {
            $('.chk-item').prop('checked', $(this).prop('checked'));
            calculateTotal();
        });

        $('.chk-item').change(function() {
            if (!$(this).prop('checked')) {
                $('#selectAll').prop('checked', false);
            }
            if ($('.chk-item:checked').length === $('.chk-item').length) {
                $('#selectAll').prop('checked', true);
            }
            calculateTotal();
        });

        function updateQty(id, change, maxStock) {
            let input = $('.qty-input_' + id);
            let currentQty = parseInt(input.val());
            let newQty = currentQty + change;
            
            if (newQty < 1) return;
            if (maxStock > 0 && newQty > maxStock) {
                alert("Số lượng yêu cầu vượt quá tồn kho!");
                return;
            }
            
            $.ajax({
                url: `/Cart/UpdateItem?cartItemId=${id}&quantity=${newQty}`,
                type: "PUT",
                success: function() {
                    location.reload();
                },
                error: function(xhr) {
                    if (xhr.status === 401) window.location.href = '/Account/Login';
                    else alert("Cập nhật thất bại. Vui lòng thử lại!");
                }
            });
        }

        function deleteCartItem(id) {
            if (!confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')) return;
            $.ajax({
                url: `/Cart/DeleteItem?cartItemId=${id}`,
                type: "DELETE",
                success: function() {
                    location.reload();
                },
                error: function(xhr) {
                    if (xhr.status === 401) window.location.href = '/Account/Login';
                    else alert("Xóa thất bại!");
                }
            });
        }

        function checkoutSelected() {
            let selectedIds = [];
            $('.chk-item:checked').each(function() {
                selectedIds.push($(this).data('id'));
            });
            if (selectedIds.length === 0) {
                alert('Vui lòng chọn ít nhất 1 sản phẩm để tiến hành thanh toán!');
                return;
            }
            
            // Redirect to checkout page with selected item IDs
            window.location.href = `/Orders/Checkout?cartItemIds=${selectedIds.join(',')}`;
        }
    </script>
}