@model IEnumerable<MVCApplication.Areas.Admin.DTOs.StaffViewModel>

@{
    ViewData["Title"] = "Staff Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalStaffs = (int)(ViewBag.TotalStaffs ?? 0);
    var pageSize = 10;
    var startItem = totalStaffs > 0 ? (currentPage - 1) * pageSize + 1 : 0;
    var endItem = Math.Min(currentPage * pageSize, totalStaffs);
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title">Staff Management</h3>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add New Staff
                    </a>
                </div>
                <div class="card-body">
                    <!-- Search & Filter Form -->
                    <form method="get" asp-action="Index" class="mb-4">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input type="text" name="keyword" class="form-control"
                                       placeholder="Search by name, email, phone..."
                                       value="@ViewBag.Keyword"
                                       maxlength="100" />
                            </div>
                            <div class="col-md-2">
                                <select name="role" class="form-control">
                                    <option value="">All Roles</option>
                                    <option value="Staff" selected="@(ViewBag.Role == "Staff")">Staff</option>
                                    <option value="Admin" selected="@(ViewBag.Role == "Admin")">Admin</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <select name="status" class="form-control">
                                    <option value="">All Status</option>
                                    <option value="true" selected="@(ViewBag.Status != null && (bool)ViewBag.Status == true)">Active</option>
                                    <option value="false" selected="@(ViewBag.Status != null && (bool)ViewBag.Status == false)">Deleted</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </div>
                            <div class="col-md-2">
                                <a asp-action="Index" class="btn btn-secondary btn-block">
                                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                                </a>
                            </div>
                        </div>
                    </form>

                    <!-- Staff Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Avatar</th>
                                    <th>ID</th>
                                    <th>Full Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            No staff found.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var staff in Model)
                                    {
                                        <tr>
                                            <td class="text-center" style="width: 60px;">
                                                @if (!string.IsNullOrEmpty(staff.Avatar))
                                                {
                                                    <img src="@staff.Avatar" alt="Avatar" class="rounded-circle"
                                                         style="width: 40px; height: 40px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center"
                                                         style="width: 40px; height: 40px;">
                                                        <i class="bi bi-person-fill text-white"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <strong>@staff.StaffId</strong>
                                            </td>
                                            <td>@staff.FullName</td>
                                            <td>@staff.Email</td>
                                            <td>@staff.Phone</td>
                                            <td>
                                                @if (staff.Role == "Admin")
                                                {
                                                    <span class="badge bg-primary">Admin</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">Staff</span>
                                                }
                                            </td>
                                            <td>
                                                @if (staff.Status)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Deleted</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group">
                                                    <a asp-action="Details" asp-route-id="@staff.StaffId"
                                                       class="btn btn-sm btn-outline-secondary" title="Details">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@staff.StaffId"
                                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    @if (staff.Status)
                                                    {
                                                        <form asp-action="Delete" asp-route-id="@staff.StaffId" method="post" style="display:inline;">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                                    title="Delete"
                                                                    onclick="return confirm('Are you sure you want to delete this staff?');">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (totalPages > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div class="text-muted">
                                Showing @startItem to @endItem of @totalStaffs staff members
                            </div>
                            <nav>
                                <ul class="pagination mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new {
                                            keyword = ViewBag.Keyword,
                                            role = ViewBag.Role,
                                            status = ViewBag.Status,
                                            page = currentPage - 1
                                        })">Previous</a>
                                    </li>

                                    @for (int i = 1; i <= totalPages; i++)
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("Index", new {
                                                keyword = ViewBag.Keyword,
                                                role = ViewBag.Role,
                                                status = ViewBag.Status,
                                                page = i
                                            })">@i</a>
                                        </li>
                                    }

                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new {
                                            keyword = ViewBag.Keyword,
                                            role = ViewBag.Role,
                                            status = ViewBag.Status,
                                            page = currentPage + 1
                                        })">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
