@using MVCApplication.Areas.Admin.DTOs
@model IReadOnlyList<ReadCategoryDto>

@{
    ViewData["Title"] = "Categories";
    var keyword = (string?)ViewBag.Keyword;
    var status = (string?)ViewBag.Status;
}

<div class="pagetitle">
    <h1>Categories</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">Categories</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Categories Management</h5>
                        <a class="btn btn-primary" asp-area="Admin" asp-controller="Categories" asp-action="Create">
                            <i class="bi bi-plus-circle me-1"></i>Thêm mới
                        </a>
                    </div>

                    <form method="get" class="row g-2 align-items-end mt-2">
                        <div class="col-md-5 col-lg-4">
                            <label class="form-label">Tìm kiếm</label>
                            <input name="keyword" value="@keyword" class="form-control" placeholder="Nhập từ khóa..." />
                        </div>
                        <div class="col-md-4 col-lg-3">
                            <label class="form-label">Trạng thái</label>
                            <select name="status" class="form-select">
                                @{
                                    var s = status ?? "All";
                                }
                                @if (s == "All")
                                {
                                    <option value="All" selected="selected">Tất cả</option>
                                }
                                else
                                {
                                    <option value="All">Tất cả</option>
                                }

                                @if (s == "Active")
                                {
                                    <option value="Active" selected="selected">Active</option>
                                }
                                else
                                {
                                    <option value="Active">Active</option>
                                }

                                @if (s == "Inactive")
                                {
                                    <option value="Inactive" selected="selected">Inactive</option>
                                }
                                else
                                {
                                    <option value="Inactive">Inactive</option>
                                }

                                @if (s == "Deleted")
                                {
                                    <option value="Deleted" selected="selected">Deleted</option>
                                }
                                else
                                {
                                    <option value="Deleted">Deleted</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 col-lg-5 d-flex gap-2">
                            <button class="btn btn-outline-primary" type="submit">
                                <i class="bi bi-search me-1"></i>Search
                            </button>
                            <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                                Reset
                            </a>
                        </div>
                    </form>

                    <div class="table-responsive mt-3">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 90px;">ID</th>
                                    <th>Tên</th>
                                    <th>Mô tả</th>
                                    <th style="width: 140px;">Trạng thái</th>
                                    <th style="width: 190px;" class="text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model == null || Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">Không có dữ liệu</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var c in Model)
                                    {
                                        <tr>
                                            <td>@c.CategoryID</td>
                                            <td class="fw-semibold">@c.CategoryName</td>
                                            <td class="text-truncate" style="max-width: 420px;">@c.Description</td>
                                            <td>
                                                @if (string.Equals(c.Status, "Active", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else if (string.Equals(c.Status, "Deleted", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <span class="badge bg-danger">Deleted</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@c.Status</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-primary"
                                                   asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@c.CategoryID">
                                                    <i class="bi bi-pencil-square me-1"></i>Sửa
                                                </a>

                                                @* Chỉ hiển thị nút Xóa khi chưa bị xóa mềm *@
                                                @if (!string.Equals(c.Status, "Deleted", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <form method="post"
                                                          asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@c.CategoryID"
                                                          class="d-inline"
                                                          onsubmit="return confirm('Bạn có chắc muốn xóa category này?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-trash me-1"></i>Xóa
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

