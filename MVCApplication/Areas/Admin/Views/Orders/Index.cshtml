@model IEnumerable<MVCApplication.Models.DTOs.Order>

@{
    ViewData["Title"] = "Orders Management";

    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;

    string q(string? v) => string.IsNullOrWhiteSpace(v) ? "" : System.Net.WebUtility.UrlEncode(v!);
    string baseUrl = Url.Action("Index", "Orders", new { area = "Admin" }) ?? "/Admin/Orders";
    string buildPageUrl(int p) =>
        baseUrl + "?" +
        $"orderId={q(ViewBag.OrderId as string)}&customerId={q(ViewBag.CustomerId as string)}&from={q(ViewBag.From as string)}&to={q(ViewBag.To as string)}&shippingStatus={q(ViewBag.ShippingStatus as string)}&paymentStatus={q(ViewBag.PaymentStatus as string)}&page={p}";
}

<h1 class="mb-4">Orders Management</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Search form -->
<form method="get" class="row g-2 mb-3">
    <div class="col-sm-2">
        <input name="orderId" value="@(ViewBag.OrderId ?? "")" class="form-control" placeholder="Order ID" />
    </div>
    <div class="col-sm-2">
        <input name="customerId" value="@(ViewBag.CustomerId ?? "")" class="form-control" placeholder="Customer" />
    </div>
    <div class="col-sm-2">
        <input type="date" name="from" value="@(ViewBag.From ?? "")" class="form-control" />
    </div>
    <div class="col-sm-2">
        <input type="date" name="to" value="@(ViewBag.To ?? "")" class="form-control" />
    </div>
    <div class="col-sm-2">
        <select name="shippingStatus" class="form-select">
            <option value="">All shipping</option>
            <option value="Pending" selected="@(ViewBag.ShippingStatus == "Pending")">Pending</option>
            <option value="Approved" selected="@(ViewBag.ShippingStatus == "Approved")">Approved</option>
            <option value="Cancelled" selected="@(ViewBag.ShippingStatus == "Cancelled")">Cancelled</option>
            <option value="Returned" selected="@(ViewBag.ShippingStatus == "Returned")">Returned</option>
        </select>
    </div>
    <div class="col-sm-2">
        <select name="paymentStatus" class="form-select">
            <option value="">All payment</option>
            <option value="Pending" selected="@(ViewBag.PaymentStatus == "Pending")">Pending</option>
            <option value="Paid" selected="@(ViewBag.PaymentStatus == "Paid")">Paid</option>
            <option value="Refunded" selected="@(ViewBag.PaymentStatus == "Refunded")">Refunded</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Orders", new { area = "Admin" })">Reset</a>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Order Date</th>
            <th class="text-end">Total</th>
            <th>Payment</th>
            <th>Shipping</th>
            <th style="width:220px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center">No orders found.</td>
            </tr>
        }
        else
        {
            foreach (var o in Model)
            {
                <tr>
                    <td>@o.OrderID</td>
                    <td>@(string.IsNullOrWhiteSpace(o.CustomerID) ? "-" : o.CustomerID)</td>
                    <td>@(o.OrderDate.HasValue ? o.OrderDate.Value.ToString("yyyy-MM-dd HH:mm") : "-")</td>
                    <td class="text-end">@((o.TotalAmount ?? 0).ToString("C"))</td>
                    <td>@(o.PaymentStatus ?? "-")</td>
                    <td>@(o.ShippingStatus ?? "-")</td>
                    <td>

                        <button class="btn btn-sm btn-info btn-show-details"
                                data-orderid="@o.OrderID">
                            Details
                        </button>

                        @{
                            bool isPendingShipping = string.Equals(o.ShippingStatus ?? "", "Pending", StringComparison.OrdinalIgnoreCase);
                            bool isPaid = string.Equals(o.PaymentStatus ?? "", "Paid", StringComparison.OrdinalIgnoreCase);
                            bool needAction = isPendingShipping && !isPaid;
                        }

                        @if (isPendingShipping && !isPaid)
                        {
                            <button type="button"
                                    class="btn btn-sm btn-warning me-1 btn-open-update"
                                    data-orderid="@o.OrderID"
                                    data-currentstatus="@o.ShippingStatus">

                                Update

                                @* red exclamation *@
                                @if (needAction)
                                {
                                    <span class="text-danger fw-bold ms-1">!</span>
                                }

                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    class="btn btn-sm btn-warning me-1"
                                    disabled
                                    title="Paid or non-pending orders cannot be modified">
                                Update
                            </button>
                        }

                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- Pagination with ellipsis -->
@if (totalPages > 1)
{
<nav>
    <ul class="pagination">

        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link" href="@(buildPageUrl(currentPage - 1))">Previous</a>
        </li>

        @{
            int window = 5;
            int start = Math.Max(1, currentPage - 2);
            int end = Math.Min(totalPages, start + window - 1);

            if (end - start + 1 < window)
            {
                start = Math.Max(1, end - window + 1);
            }
        }

        @if (start > 1)
        {
            <li class="page-item">
                <a class="page-link" href="@(buildPageUrl(1))">1</a>
            </li>

            @if (start > 2)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }
        }

        @for (int i = start; i <= end; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link" href="@(buildPageUrl(i))">@i</a>
            </li>
        }

        @if (end < totalPages)
        {
            @if (end < totalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            <li class="page-item">
                <a class="page-link" href="@(buildPageUrl(totalPages))">@totalPages</a>
            </li>
        }

        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
            <a class="page-link" href="@(buildPageUrl(currentPage + 1))">Next</a>
        </li>

    </ul>
</nav>
}

<!-- Update status modal -->
<div class="modal fade" id="updateModal" tabindex="-1" aria-labelledby="updateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="updateForm" method="post" asp-action="UpdateStatus" asp-controller="Orders" asp-area="Admin">
            @Html.AntiForgeryToken()
            <input type="hidden" name="orderId" id="modalOrderId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="updateModalLabel">Update Order Status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="modalNewStatus" class="form-label">New Shipping Status</label>
                        <select id="modalNewStatus" name="newStatus" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    <p class="text-muted small">Updating status will change the shipping state for this order.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Confirm Update</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="orderDetailsModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Order Details</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="orderDetailsContent">
                <div class="text-center p-4">
                    <div class="spinner-border"></div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var updateModalEl = document.getElementById('updateModal');
            var updateModal = new bootstrap.Modal(updateModalEl);
            document.querySelectorAll('.btn-open-update').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var orderId = btn.getAttribute('data-orderid');
                    var current = btn.getAttribute('data-currentstatus') || 'Pending';
                    document.getElementById('modalOrderId').value = orderId;
                    var sel = document.getElementById('modalNewStatus');
                    sel.value = current;
                    updateModal.show();
                });
            });

        })();

        document.addEventListener("click", function (e) {

            const btn = e.target.closest(".btn-show-details");

            if (!btn) return;

            const orderId = btn.dataset.orderid;

            const modal = new bootstrap.Modal(
                document.getElementById("orderDetailsModal")
            );

            const container = document.getElementById("orderDetailsContent");

            container.innerHTML =
                '<div class="text-center p-4"><div class="spinner-border"></div></div>';

            fetch(`/Admin/Orders/Details?orderId=${orderId}`)
                .then(res => res.text())
                .then(html => {
                    container.innerHTML = html;
                });

            modal.show();
        });

        document.getElementById("updateForm").addEventListener("submit", async function (e) {

            e.preventDefault();

            const form = this;
            const formData = new FormData(form);

            const res = await fetch(form.action, {
                method: "POST",
                body: formData
            });

            const data = await res.json();

            if (data.success) {

                alert(data.message);

                location.reload(); // reload lại trang list

            } else {

                alert(data.message);

            }

        });
    </script>
}

