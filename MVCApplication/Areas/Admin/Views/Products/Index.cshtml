@{
    ViewData["Title"] = "Products Management";
}

<div class="pagetitle">
    <h1>Products Management</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin">Home</a></li>
            <li class="breadcrumb-item active">Products</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
                        <div class="d-flex gap-2">
                            <input type="text" id="searchInput" class="form-control" placeholder="Search products..." style="width:260px;">
                            <button class="btn btn-outline-secondary" onclick="searchProducts()">
                                <i class="bi bi-search"></i> Search
                            </button>
                            <button class="btn btn-outline-secondary" onclick="loadProducts()">
                                <i class="bi bi-arrow-clockwise"></i> Reset
                            </button>
                        </div>
                        <button class="btn btn-primary" onclick="openCreateModal()">
                            <i class="bi bi-plus-circle"></i> Add Product
                        </button>
                    </div>

                    <div id="alertBox"></div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Image</th>
                                    <th>Product Name</th>
                                    <th>Category</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="productsTableBody">
                                <tr>
                                    <td colspan="8" class="text-center">
                                        <div class="spinner-border spinner-border-sm text-primary"></div> Loading...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- View Detail Modal -->
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-eye me-1"></i> Product Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="viewModalBody">
                <div class="text-center py-3"><div class="spinner-border text-primary"></div></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-1"></i> Add Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Product Name <span class="text-danger">*</span></label>
                        <input type="text" id="createName" class="form-control" placeholder="Enter product name">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Category <span class="text-danger">*</span></label>
                        <select id="createCategory" class="form-select"></select>
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="createDescription" class="form-control" rows="2" placeholder="Enter description"></textarea>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Material</label>
                        <input type="text" id="createMaterial" class="form-control" placeholder="Enter material">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Price <span class="text-danger">*</span></label>
                        <input type="number" id="createPrice" class="form-control" placeholder="0" min="0" step="0.01">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Discount (%)</label>
                        <input type="number" id="createDiscount" class="form-control" placeholder="0" min="0" max="100" step="0.01">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Stock Quantity <span class="text-danger">*</span></label>
                        <input type="number" id="createStock" class="form-control" placeholder="0" min="0">
                    </div>
                </div>
                <hr>
                <h6>Product Images (exactly 4 required, select 1 as main)</h6>
                <div id="createImagesContainer">
                    <div class="row mb-2 image-row">
                        <div class="col-md-9">
                            <input type="text" class="form-control img-url" placeholder="Image URL">
                        </div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input img-main" type="radio" name="createMainImg" value="0">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2 image-row">
                        <div class="col-md-9">
                            <input type="text" class="form-control img-url" placeholder="Image URL">
                        </div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input img-main" type="radio" name="createMainImg" value="1">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2 image-row">
                        <div class="col-md-9">
                            <input type="text" class="form-control img-url" placeholder="Image URL">
                        </div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input img-main" type="radio" name="createMainImg" value="2">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2 image-row">
                        <div class="col-md-9">
                            <input type="text" class="form-control img-url" placeholder="Image URL">
                        </div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input img-main" type="radio" name="createMainImg" value="3">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="createProduct()">
                    <i class="bi bi-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-1"></i> Edit Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Product Name <span class="text-danger">*</span></label>
                        <input type="text" id="editName" class="form-control">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Category <span class="text-danger">*</span></label>
                        <select id="editCategory" class="form-select"></select>
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="editDescription" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Material</label>
                        <input type="text" id="editMaterial" class="form-control">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Price <span class="text-danger">*</span></label>
                        <input type="number" id="editPrice" class="form-control" min="0" step="0.01">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Discount (%)</label>
                        <input type="number" id="editDiscount" class="form-control" min="0" max="100" step="0.01">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Stock Quantity <span class="text-danger">*</span></label>
                        <input type="number" id="editStock" class="form-control" min="0">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Status</label>
                        <select id="editStatus" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>
                <hr>
                <h6>Product Images (exactly 4 required, select 1 as main)</h6>
                <div id="editImagesContainer">
                    <div class="row mb-2">
                        <div class="col-md-9"><input type="text" class="form-control edit-img-url" placeholder="Image URL"></div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input edit-img-main" type="radio" name="editMainImg" value="0">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-9"><input type="text" class="form-control edit-img-url" placeholder="Image URL"></div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input edit-img-main" type="radio" name="editMainImg" value="1">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-9"><input type="text" class="form-control edit-img-url" placeholder="Image URL"></div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input edit-img-main" type="radio" name="editMainImg" value="2">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-9"><input type="text" class="form-control edit-img-url" placeholder="Image URL"></div>
                        <div class="col-md-3 d-flex align-items-center">
                            <div class="form-check">
                                <input class="form-check-input edit-img-main" type="radio" name="editMainImg" value="3">
                                <label class="form-check-label">Main</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" onclick="updateProduct()">
                    <i class="bi bi-save"></i> Update
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Approve/Reject/Delete Confirm Modal -->
<div class="modal fade" id="actionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" id="actionModalHeader">
                <h5 class="modal-title" id="actionModalTitle">Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="actionModalMessage"></p>
                <input type="hidden" id="actionProductId">
                <input type="hidden" id="actionType">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn" id="actionConfirmBtn" onclick="confirmAction()">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let categoriesList = [];

    function showAlert(message, type = 'success') {
        const box = document.getElementById('alertBox');
        box.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>`;
        setTimeout(() => box.innerHTML = '', 5000);
    }

    function escHtml(str) {
        return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function formatPrice(price) {
        return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(price);
    }

    function getStatusBadge(status) {
        const map = {
            'Approved': 'bg-success',
            'Pending': 'bg-warning text-dark',
            'Rejected': 'bg-danger',
            'Inactive': 'bg-secondary'
        };
        return `<span class="badge ${map[status] || 'bg-secondary'}">${escHtml(status)}</span>`;
    }

    async function loadCategories() {
        try {
            const res = await fetch('/Admin/Products/GetCategories');
            categoriesList = await res.json();
        } catch (e) {
            categoriesList = [];
        }
    }

    function populateCategorySelect(selectId, selectedName) {
        const sel = document.getElementById(selectId);
        sel.innerHTML = categoriesList.map(c =>
            `<option value="${c.categoryID}" ${c.categoryName === selectedName ? 'selected' : ''}>${escHtml(c.categoryName)}</option>`
        ).join('');
    }

    async function loadProducts() {
        document.getElementById('searchInput').value = '';
        const tbody = document.getElementById('productsTableBody');
        tbody.innerHTML = '<tr><td colspan="8" class="text-center"><div class="spinner-border spinner-border-sm text-primary"></div> Loading...</td></tr>';

        try {
            const res = await fetch('/Admin/Products/GetAll');
            const data = await res.json();
            renderTable(data);
        } catch (e) {
            tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Failed to load data.</td></tr>';
        }
    }

    async function searchProducts() {
        const keyword = document.getElementById('searchInput').value.trim();
        const tbody = document.getElementById('productsTableBody');
        tbody.innerHTML = '<tr><td colspan="8" class="text-center"><div class="spinner-border spinner-border-sm text-primary"></div> Searching...</td></tr>';

        try {
            const url = keyword ? `/Admin/Products/Search?keyword=${encodeURIComponent(keyword)}` : '/Admin/Products/GetAll';
            const res = await fetch(url);
            const data = await res.json();
            renderTable(data);
        } catch (e) {
            tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Failed to search.</td></tr>';
        }
    }

    function renderTable(products) {
        const tbody = document.getElementById('productsTableBody');
        if (!products || products.length === 0) {
            tbody.innerHTML = '<tr><td colspan="8" class="text-center">No products found.</td></tr>';
            return;
        }
        tbody.innerHTML = products.map((p, i) => `
            <tr>
                <td>${i + 1}</td>
                <td>
                    ${p.mainImage
                        ? `<img src="${escHtml(p.mainImage)}" alt="img" style="width:50px;height:50px;object-fit:cover;border-radius:4px;">`
                        : '<span class="text-muted small">No image</span>'}
                </td>
                <td>${escHtml(p.productName)}</td>
                <td>${escHtml(p.categoryName)}</td>
                <td>${formatPrice(p.price)}</td>
                <td>${p.stockQuantity}</td>
                <td>${getStatusBadge(p.status)}</td>
                <td>
                    <button class="btn btn-sm btn-info text-white me-1" title="View" onclick="openViewModal('${escHtml(p.productID)}')">
                        <i class="bi bi-eye"></i>
                    </button>
                    <button class="btn btn-sm btn-warning me-1" title="Edit" onclick="openEditModal('${escHtml(p.productID)}')">
                        <i class="bi bi-pencil"></i>
                    </button>
                    ${p.status === 'Pending' || p.status === 'Rejected' ? `
                    <button class="btn btn-sm btn-success me-1" title="Approve" onclick="openActionModal('${escHtml(p.productID)}', 'approve', '${escHtml(p.productName)}')">
                        <i class="bi bi-check-circle"></i>
                    </button>` : ''}
                    ${p.status === 'Pending' || p.status === 'Approved' ? `
                    <button class="btn btn-sm btn-secondary me-1" title="Reject" onclick="openActionModal('${escHtml(p.productID)}', 'reject', '${escHtml(p.productName)}')">
                        <i class="bi bi-x-circle"></i>
                    </button>` : ''}
                    ${p.status !== 'Inactive' ? `
                    <button class="btn btn-sm btn-danger" title="Inactivate" onclick="openActionModal('${escHtml(p.productID)}', 'delete', '${escHtml(p.productName)}')">
                        <i class="bi bi-trash"></i>
                    </button>` : ''}
                </td>
            </tr>`).join('');
    }

    async function openViewModal(id) {
        document.getElementById('viewModalBody').innerHTML = '<div class="text-center py-3"><div class="spinner-border text-primary"></div></div>';
        new bootstrap.Modal(document.getElementById('viewModal')).show();

        try {
            const res = await fetch(`/Admin/Products/Get?id=${encodeURIComponent(id)}`);
            if (!res.ok) throw new Error();
            const p = await res.json();

            const imagesHtml = p.images && p.images.length > 0
                ? p.images.map(img => `<img src="${escHtml(img)}" alt="img" style="width:80px;height:80px;object-fit:cover;border-radius:4px;margin:4px;">`).join('')
                : '<span class="text-muted">No images</span>';

            document.getElementById('viewModalBody').innerHTML = `
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>ID:</strong> ${escHtml(p.productID)}</p>
                        <p><strong>Name:</strong> ${escHtml(p.productName)}</p>
                        <p><strong>Category:</strong> ${escHtml(p.categoryName)}</p>
                        <p><strong>Material:</strong> ${escHtml(p.material || 'N/A')}</p>
                        <p><strong>Price:</strong> ${formatPrice(p.price)}</p>
                        <p><strong>Discount:</strong> ${p.discount}%</p>
                        <p><strong>Stock:</strong> ${p.stockQuantity}</p>
                        <p><strong>Status:</strong> ${getStatusBadge(p.status)}</p>
                        <p><strong>Created:</strong> ${new Date(p.createdAt).toLocaleDateString('vi-VN')}</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Description:</strong></p>
                        <p class="text-muted">${escHtml(p.description || 'N/A')}</p>
                    </div>
                    <div class="col-12 mt-2">
                        <p><strong>Images:</strong></p>
                        <div>${imagesHtml}</div>
                    </div>
                </div>`;
        } catch (e) {
            document.getElementById('viewModalBody').innerHTML = '<div class="alert alert-danger">Failed to load product details.</div>';
        }
    }

    async function openCreateModal() {
        await loadCategories();
        populateCategorySelect('createCategory', null);
        document.getElementById('createName').value = '';
        document.getElementById('createDescription').value = '';
        document.getElementById('createMaterial').value = '';
        document.getElementById('createPrice').value = '';
        document.getElementById('createDiscount').value = '0';
        document.getElementById('createStock').value = '';
        document.querySelectorAll('#createImagesContainer .img-url').forEach(el => el.value = '');
        document.querySelectorAll('#createImagesContainer .img-main').forEach(el => el.checked = false);
        new bootstrap.Modal(document.getElementById('createModal')).show();
    }

    async function createProduct() {
        const name = document.getElementById('createName').value.trim();
        const categoryID = parseInt(document.getElementById('createCategory').value);
        const description = document.getElementById('createDescription').value.trim();
        const material = document.getElementById('createMaterial').value.trim();
        const price = parseFloat(document.getElementById('createPrice').value);
        const discount = parseFloat(document.getElementById('createDiscount').value || '0');
        const stockQuantity = parseInt(document.getElementById('createStock').value);

        if (!name) { showAlert('Product name is required.', 'danger'); return; }
        if (!categoryID) { showAlert('Please select a category.', 'danger'); return; }
        if (isNaN(price) || price <= 0) { showAlert('Please enter a valid price.', 'danger'); return; }
        if (isNaN(stockQuantity) || stockQuantity < 0) { showAlert('Please enter a valid stock quantity.', 'danger'); return; }

        const imgUrls = [...document.querySelectorAll('#createImagesContainer .img-url')].map(el => el.value.trim());
        const mainRadios = [...document.querySelectorAll('#createImagesContainer .img-main')];
        const mainIndex = mainRadios.findIndex(r => r.checked);

        if (imgUrls.some(url => !url)) { showAlert('Please fill in all 4 image URLs.', 'danger'); return; }
        if (mainIndex === -1) { showAlert('Please select a main image.', 'danger'); return; }

        const images = imgUrls.map((url, idx) => ({ imageUrl: url, isMain: idx === mainIndex }));

        const dto = { categoryID, productName: name, description, material, price, discount, stockQuantity, images };

        const res = await fetch('/Admin/Products/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(dto)
        });

        if (res.ok) {
            bootstrap.Modal.getInstance(document.getElementById('createModal')).hide();
            showAlert('Product created successfully.');
            loadProducts();
        } else {
            const err = await res.json().catch(() => ({ message: 'Failed to create product.' }));
            showAlert(err.message || 'Failed to create product.', 'danger');
        }
    }

    async function openEditModal(id) {
        await loadCategories();
        const res = await fetch(`/Admin/Products/Get?id=${encodeURIComponent(id)}`);
        if (!res.ok) { showAlert('Failed to load product.', 'danger'); return; }
        const p = await res.json();

        document.getElementById('editId').value = p.productID;
        document.getElementById('editName').value = p.productName;
        document.getElementById('editDescription').value = p.description || '';
        document.getElementById('editMaterial').value = p.material || '';
        document.getElementById('editPrice').value = p.price;
        document.getElementById('editDiscount').value = p.discount;
        document.getElementById('editStock').value = p.stockQuantity;
        document.getElementById('editStatus').value = p.status;

        populateCategorySelect('editCategory', p.categoryName);

        const imgUrls = document.querySelectorAll('#editImagesContainer .edit-img-url');
        const imgMains = document.querySelectorAll('#editImagesContainer .edit-img-main');
        for (let i = 0; i < 4; i++) {
            imgUrls[i].value = p.images && p.images[i] ? p.images[i] : '';
            imgMains[i].checked = false;
        }
        // The API's ProductDetailDto returns images as a flat list without indicating which is main.
        // Default to first image as main; the user can change it before saving.
        if (imgMains.length > 0) imgMains[0].checked = true;

        new bootstrap.Modal(document.getElementById('editModal')).show();
    }

    async function updateProduct() {
        const id = document.getElementById('editId').value;
        const name = document.getElementById('editName').value.trim();
        const categoryID = parseInt(document.getElementById('editCategory').value);
        const description = document.getElementById('editDescription').value.trim();
        const material = document.getElementById('editMaterial').value.trim();
        const price = parseFloat(document.getElementById('editPrice').value);
        const discount = parseFloat(document.getElementById('editDiscount').value || '0');
        const stockQuantity = parseInt(document.getElementById('editStock').value);
        const status = document.getElementById('editStatus').value;

        if (!name) { showAlert('Product name is required.', 'danger'); return; }
        if (!categoryID) { showAlert('Please select a category.', 'danger'); return; }
        if (isNaN(price) || price <= 0) { showAlert('Please enter a valid price.', 'danger'); return; }
        if (isNaN(stockQuantity) || stockQuantity < 0) { showAlert('Please enter a valid stock quantity.', 'danger'); return; }

        const imgUrls = [...document.querySelectorAll('#editImagesContainer .edit-img-url')].map(el => el.value.trim());
        const mainRadios = [...document.querySelectorAll('#editImagesContainer .edit-img-main')];
        const mainIndex = mainRadios.findIndex(r => r.checked);

        if (imgUrls.some(url => !url)) { showAlert('Please fill in all 4 image URLs.', 'danger'); return; }
        if (mainIndex === -1) { showAlert('Please select a main image.', 'danger'); return; }

        const images = imgUrls.map((url, idx) => ({ imageUrl: url, isMain: idx === mainIndex }));

        const dto = { categoryID, productName: name, description, material, price, discount, stockQuantity, status, images };

        const res = await fetch(`/Admin/Products/Update?id=${encodeURIComponent(id)}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(dto)
        });

        if (res.ok) {
            bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
            showAlert('Product updated successfully.');
            loadProducts();
        } else {
            const err = await res.json().catch(() => ({ message: 'Failed to update product.' }));
            showAlert(err.message || 'Failed to update product.', 'danger');
        }
    }

    function openActionModal(id, action, name) {
        document.getElementById('actionProductId').value = id;
        document.getElementById('actionType').value = action;

        const header = document.getElementById('actionModalHeader');
        const title = document.getElementById('actionModalTitle');
        const msg = document.getElementById('actionModalMessage');
        const btn = document.getElementById('actionConfirmBtn');

        header.className = 'modal-header';
        if (action === 'approve') {
            header.classList.add('bg-success', 'text-white');
            title.textContent = 'Approve Product';
            msg.innerHTML = `Are you sure you want to <strong>approve</strong> product "<strong>${escHtml(name)}</strong>"?`;
            btn.className = 'btn btn-success';
            btn.textContent = 'Approve';
        } else if (action === 'reject') {
            header.classList.add('bg-secondary', 'text-white');
            title.textContent = 'Reject Product';
            msg.innerHTML = `Are you sure you want to <strong>reject</strong> product "<strong>${escHtml(name)}</strong>"?`;
            btn.className = 'btn btn-secondary';
            btn.textContent = 'Reject';
        } else {
            header.classList.add('bg-danger', 'text-white');
            title.textContent = 'Inactivate Product';
            msg.innerHTML = `Are you sure you want to <strong>inactivate</strong> product "<strong>${escHtml(name)}</strong>"?`;
            btn.className = 'btn btn-danger';
            btn.textContent = 'Inactivate';
        }

        new bootstrap.Modal(document.getElementById('actionModal')).show();
    }

    async function confirmAction() {
        const id = document.getElementById('actionProductId').value;
        const action = document.getElementById('actionType').value;

        const urlMap = {
            'approve': `/Admin/Products/Approve?id=${encodeURIComponent(id)}`,
            'reject': `/Admin/Products/Reject?id=${encodeURIComponent(id)}`,
            'delete': `/Admin/Products/Delete?id=${encodeURIComponent(id)}`
        };

        const res = await fetch(urlMap[action], { method: 'POST' });

        if (res.ok) {
            bootstrap.Modal.getInstance(document.getElementById('actionModal')).hide();
            const msgMap = { approve: 'Product approved.', reject: 'Product rejected.', delete: 'Product inactivated.' };
            showAlert(msgMap[action] || 'Action completed.');
            loadProducts();
        } else {
            const err = await res.json().catch(() => ({ message: 'Action failed.' }));
            showAlert(err.message || 'Action failed.', 'danger');
        }
    }

    document.getElementById('searchInput').addEventListener('keyup', function (e) {
        if (e.key === 'Enter') searchProducts();
    });

    document.addEventListener('DOMContentLoaded', loadProducts);
</script>
}
