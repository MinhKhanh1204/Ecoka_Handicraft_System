@using MVCApplication.Areas.Admin.DTOs
@using MVCApplication.CustomFormatter
@model PagedResult<VoucherListDto>

@{
    ViewData["Title"] = "Voucher Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var keyword = ViewBag.Keyword as string;
    var status = ViewBag.Status as string;
    var sortBy = ViewBag.SortBy as string ?? "id_asc";
}

<div class="pagetitle">
    <h1>Voucher Management</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">Voucher Management</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-4">
                        <h5 class="card-title mb-0">Vouchers</h5>
                        <a class="btn btn-primary" asp-action="Create">
                            <i class="bi bi-plus-circle me-1"></i> Add Voucher
                        </a>
                    </div>

                    <!-- Search & Filter (UC_47) -->
                    <form method="get" class="mb-4">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input type="text" name="keyword" class="form-control"
                                       placeholder="Search by name, code, discount..."
                                       value="@keyword" />
                            </div>
                            <div class="col-md-2">
                                <select name="status" class="form-select" onchange="this.form.submit()">
                                    <option value="">All Status</option>
                                    <option value="Active" selected="@(status == "Active")">Active</option>
                                    <option value="Inactive" selected="@(status == "Inactive")">Inactive</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <select name="sortBy" class="form-select" onchange="this.form.submit()">
                                    <option value="id_asc" selected="@(sortBy == "id_asc")">ID: Low to High</option>
                                    <option value="id_desc" selected="@(sortBy == "id_desc")">ID: High to Low</option>
                                    <option value="name_asc" selected="@(sortBy == "name_asc")">Name: A-Z</option>
                                    <option value="name_desc" selected="@(sortBy == "name_desc")">Name: Z-A</option>
                                    <option value="expiry_asc" selected="@(sortBy == "expiry_asc")">Expiry: Earliest</option>
                                    <option value="expiry_desc" selected="@(sortBy == "expiry_desc")">Expiry: Latest</option>
                                    <option value="discount_desc" selected="@(sortBy == "discount_desc")">Discount: High</option>
                                    <option value="discount_asc" selected="@(sortBy == "discount_asc")">Discount: Low</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-search me-1"></i> Search
                                </button>
                            </div>
                            <div class="col-md-2">
                                <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
                            </div>
                        </div>
                    </form>

                    <!-- Table (UC_46) -->
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Discount %</th>
                                    <th>Max Reducing</th>
                                    <th>Quantity</th>
                                    <th>Expiry Date</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Items == null || !Model.Items.Any())
                                {
                                    <tr>
                                        <td colspan="9" class="text-center text-muted py-5">
                                            <i class="bi bi-ticket-perforated display-4 d-block mb-3"></i>
                                            No vouchers found.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var v in Model.Items)
                                    {
                                        <tr>
                                            <td><strong>@v.VoucherId</strong></td>
                                            <td>@v.VoucherName</td>
                                            <td><code>@v.Code</code></td>
                                            <td>@(v.DiscountPercentage?.ToString("0.#") ?? "-")%</td>
                                            <td>@(v.MaxReducing.HasValue ? v.MaxReducing.Value.ToString("N0") : "-")</td>
                                            <td>@v.Quantity</td>
                                            <td>@v.ExpiryDate?.ToString("yyyy-MM-dd")</td>
                                            <td>
                                                @if (v.IsActive == true)
                                                { <span class="badge bg-success">Active</span> }
                                                else
                                                { <span class="badge bg-secondary">Inactive</span> }
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group">
                                                    <a asp-action="Details" asp-route-id="@v.VoucherId" class="btn btn-sm btn-outline-info" title="View">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@v.VoucherId" class="btn btn-sm btn-outline-primary" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form asp-action="Delete" asp-route-id="@v.VoucherId" method="post" class="d-inline"
                                                          onsubmit="return confirm('Are you sure you want to delete this voucher?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)"
                                       asp-route-keyword="@keyword" asp-route-status="@status" asp-route-sortBy="@sortBy">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i"
                                           asp-route-keyword="@keyword" asp-route-status="@status" asp-route-sortBy="@sortBy">@i</a>
                                    </li>
                                }
                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)"
                                       asp-route-keyword="@keyword" asp-route-status="@status" asp-route-sortBy="@sortBy">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                        <p class="text-muted small text-center">Showing @((Model.PageNumber - 1) * Model.PageSize + 1) to @Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount) of @Model.TotalCount vouchers</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
