@using MVCApplication.Areas.Admin.DTOs
@model VoucherDetailDto

@{
    ViewData["Title"] = "Voucher Details";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="pagetitle">
    <h1>Voucher Details (UC_51)</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Voucher Management</a></li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-ticket-perforated me-2"></i>@Model.VoucherName
                        @if (Model.IsActive == true)
                        { <span class="badge bg-light text-dark ms-2">Active</span> }
                        else
                        { <span class="badge bg-secondary ms-2">Inactive</span> }
                    </h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Voucher ID</dt>
                        <dd class="col-sm-8">@Model.VoucherId</dd>

                        <dt class="col-sm-4">Code</dt>
                        <dd class="col-sm-8"><code class="fs-6">@Model.Code</code></dd>

                        <dt class="col-sm-4">Voucher Name</dt>
                        <dd class="col-sm-8">@Model.VoucherName</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "-")</dd>

                        <dt class="col-sm-4">Discount</dt>
                        <dd class="col-sm-8">@(Model.DiscountPercentage?.ToString("0.#") ?? "-")%</dd>

                        <dt class="col-sm-4">Max Reducing</dt>
                        <dd class="col-sm-8">@(Model.MaxReducing.HasValue ? Model.MaxReducing.Value.ToString("N0") + " VND" : "-")</dd>

                        <dt class="col-sm-4">Quantity</dt>
                        <dd class="col-sm-8">@Model.Quantity</dd>

                        <dt class="col-sm-4">Usage Count</dt>
                        <dd class="col-sm-8">@(Model.UsageCount ?? 0)</dd>

                        <dt class="col-sm-4">Expiry Date</dt>
                        <dd class="col-sm-8">@Model.ExpiryDate?.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4">Min Order Value</dt>
                        <dd class="col-sm-8">@(Model.MinOrderValue.HasValue ? Model.MinOrderValue.Value.ToString("N0") + " VND" : "-")</dd>

                        <dt class="col-sm-4">Max Usage Per User</dt>
                        <dd class="col-sm-8">@(Model.MaxUsagePerUser?.ToString() ?? "-")</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive == true)
                            { <span class="badge bg-success">Active</span> }
                            else
                            { <span class="badge bg-secondary">Inactive</span> }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <a asp-action="Edit" asp-route-id="@Model.VoucherId" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</section>
